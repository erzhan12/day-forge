# Copy this file to .env and fill in your values.
# cp .env.example .env

DEBUG=1

# Required in production (DEBUG=0); auto-generated fallback used in dev
DJANGO_SECRET_KEY=your-secret-key-here

# Production only — comma-separated hostnames
ALLOWED_HOSTS=yourdomain.com

# Production only — comma-separated origins
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Cache / rate-limit backend (Django RedisCache). Required when LLM_API_KEY
# is set — ai.E001 blocks an ineffective backend (LocMem/FileBased/Dummy)
# whenever AI is enabled, independent of DEBUG. Recommended for any
# production-shaped deploy (shared rate-limit counters + CalDAV event-cache
# perf). Unset + no AI key => LocMemCache fallback.
# Production: use auth (redis://default:PASSWORD@host:6379/0) and/or TLS
# (rediss://...). Never commit real credentials to version control.
REDIS_URL=redis://localhost:6379/0

# LLM — OpenAI-compatible; swap LLM_BASE_URL for OpenRouter, Ollama, etc.
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_REQUEST_TIMEOUT=15
LLM_MAX_COMMAND_CHARS=500
LLM_RATE_LIMIT_PER_HOUR=100

# Draft generation — heavier model, separate rate-limit counter
LLM_DRAFT_MODEL=gpt-4o
LLM_DRAFT_RATE_LIMIT_PER_HOUR=10
# How many past schedules feed into draft context
LLM_HISTORY_DAYS=7

# Analytics / streak
# Per-day completion ratio required for a day to count toward the streak (0.0-1.0).
ANALYTICS_STREAK_THRESHOLD=0.8
# Hard cap on how far back the streak walk goes (positive int).
ANALYTICS_STREAK_WINDOW_DAYS=30

# --- Production deploy (feature 0016) ---------------------------------------
# Set as GitHub Actions secrets; CI writes them into .env on the droplet.
# REDIS_URL is overridden by docker-compose to redis://redis:6379/0; set it
# here only for non-compose runs.
# Required for DEBUG=0 boot (calendar_sync.E001) even if CalDAV is unused.
CALDAV_ENCRYPTION_KEY=
# Required for DEBUG=0 boot (todoist_sync.E001) even if Todoist is unused.
TODOIST_ENCRYPTION_KEY=
# Background Todoist refresh while the sidebar is open (seconds). 0 = off.
TODOIST_POLL_INTERVAL_SECONDS=30
# DJANGO_SUPERUSER_* are consumed by deployment/scripts/entrypoint.sh on first
# boot to create the /admin user idempotently.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
